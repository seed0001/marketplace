generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(cuid())
  name      String?
  email     String    @unique
  password  String?
  image     String?
  phoneNumber String?
  phoneCarrier String?
  phoneNotificationsEnabled Boolean @default(false)
  phoneVerifiedAt DateTime?
  emailNotificationsEnabled Boolean @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  listings            Listing[]
  messages            Message[]
  conversationsAsBuyer  Conversation[] @relation("ConversationBuyer")
  conversationsAsSeller Conversation[] @relation("ConversationSeller")
  reviewsGiven Review[]        @relation("ReviewAuthor")
  feedbackGiven   Feedback[]    @relation("FeedbackFrom")
  feedbackReceived Feedback[]   @relation("FeedbackTo")
  listingViews  ListingView[]  @relation("ViewerViews")
  websites      SellerWebsite[]
  role          UserRole       @default(MEMBER)
  analyticsEvents AnalyticsEvent[]
  sellerAiState    SellerAiState?
  sellerAiThreads  SellerAiThread[]
  sellerMemories   SellerMemory[]
  aiSettingsUpdated AiProviderSettings[] @relation("AiSettingsUpdatedBy")
  audioSettingsUpdated SiteAudioSettings[] @relation("AudioSettingsUpdatedBy")
  ttsSettingsUpdated   TtsProviderSettings[] @relation("TtsSettingsUpdatedBy")
  moderationEvents     ContentModerationEvent[] @relation("ModerationActor")
  issueReports         SiteIssueReport[] @relation("IssueReporter")
  discordSettingsUpdated DiscordBotSettings[] @relation("DiscordSettingsUpdatedBy")
  apiKeys              SellerApiKey[]
  apiKeyUsages         SellerApiKeyUsage[]
  notificationsCreated SiteNotification[] @relation("NotificationCreatedBy")
  notificationReceipts SiteNotificationReceipt[]
  notificationTargets  SiteNotificationRecipient[]
  notificationDeliveries SiteNotificationDelivery[]
}

// A personal access token a seller generates so an external client — their
// local app or a local AI agent — can authenticate to the programmatic API
// and manage their listings. Only a SHA-256 hash of the token is stored; the
// plaintext is shown to the seller exactly once at creation time. `prefix` is
// a short, non-secret slice kept for display so a seller can tell their keys
// apart. Revoking sets `revokedAt` (soft delete) so the key stops working.
model SellerApiKey {
  id         String    @id @default(cuid())
  userId     String
  name       String
  prefix     String
  hashedKey  String    @unique
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  usages SellerApiKeyUsage[]

  @@index([userId])
  @@index([hashedKey])
}

// Request-level telemetry for the seller programmatic API. This tracks how
// valid API keys are used without storing request bodies, response bodies, raw
// IP addresses, or bearer tokens.
model SellerApiKeyUsage {
  id         String   @id @default(cuid())
  apiKeyId  String
  userId    String
  method     String
  path       String
  route      String
  statusCode Int
  userAgent  String?
  occurredAt DateTime @default(now())

  apiKey SellerApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([apiKeyId, occurredAt])
  @@index([userId, occurredAt])
  @@index([route, occurredAt])
  @@index([statusCode, occurredAt])
  @@index([occurredAt])
}

// Admin-managed catalog of carrier email-to-SMS gateways. SMS is delivered by
// emailing <number>@<domain> through the email provider, so this list is just
// the labels + gateway domains offered in the carrier picker. It's editable so
// new or regional carriers can be added without a code change; users can also
// enter a gateway not in this list via the profile "Other" field. When the
// table is empty the app falls back to a built-in default set.
model SmsGateway {
  id        String   @id @default(cuid())
  label     String
  domain    String   @unique
  enabled   Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enabled, sortOrder])
}

model DiscordBotSettings {
  id                    String   @id @default("default")
  enabled               Boolean  @default(false)
  guildId               String?
  applicationId         String?
  encryptedBotToken     String?
  botTokenIv            String?
  botTokenTag           String?
  openRouterModel       String   @default("openrouter/auto")
  encryptedOpenRouterKey String?
  openRouterKeyIv       String?
  openRouterKeyTag      String?
  updatedById           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  updatedBy User? @relation("DiscordSettingsUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
}

model DiscordChannelConfig {
  id           String   @id @default(cuid())
  eventType    String   @unique
  label        String
  channelId    String?
  channelName  String?
  systemPrompt String
  enabled      Boolean  @default(false)
  mentionRoleId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  deliveries DiscordDelivery[]
}

model DiscordDelivery {
  id               String   @id @default(cuid())
  eventType        String
  title            String
  payload          Json
  status           String   @default("pending")
  attempts         Int      @default(0)
  lastError        String?
  discordMessageId String?
  channelConfigId  String?
  createdAt        DateTime @default(now())
  deliveredAt      DateTime?
  updatedAt        DateTime @updatedAt

  channelConfig DiscordChannelConfig? @relation(fields: [channelConfigId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([eventType, createdAt])
  @@index([channelConfigId])
}

model SiteIssueReport {
  id           String   @id @default(cuid())
  affectedPage String
  description  String
  contact      String
  status       String   @default("open")
  userAgent    String?
  reporterId   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  reporter User? @relation("IssueReporter", fields: [reporterId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([reporterId])
}

model SiteNotification {
  id          String    @id @default(cuid())
  title       String
  body        String
  category    String    @default("update")
  priority    String    @default("normal")
  audience    String    @default("all")
  linkLabel   String?
  linkHref    String?
  startsAt    DateTime  @default(now())
  expiresAt   DateTime?
  archivedAt  DateTime?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdBy User? @relation("NotificationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  receipts  SiteNotificationReceipt[]
  targets   SiteNotificationRecipient[]
  deliveries SiteNotificationDelivery[]

  @@index([startsAt])
  @@index([expiresAt])
  @@index([archivedAt])
  @@index([category, startsAt])
  @@index([priority, startsAt])
  @@index([createdById])
}

model SiteNotificationRecipient {
  id             String   @id @default(cuid())
  notificationId String
  userId         String
  createdAt      DateTime @default(now())

  notification SiteNotification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([userId])
  @@index([notificationId])
}

model SiteNotificationReceipt {
  id             String    @id @default(cuid())
  notificationId String
  userId         String
  readAt         DateTime?
  dismissedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  notification SiteNotification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([userId, readAt])
  @@index([userId, dismissedAt])
  @@index([notificationId])
}

model SiteNotificationDelivery {
  id             String    @id @default(cuid())
  notificationId String
  userId         String
  channel        String
  status         String
  error          String?
  providerId     String?
  createdAt      DateTime  @default(now())
  deliveredAt    DateTime?

  notification SiteNotification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([notificationId])
  @@index([userId, createdAt])
  @@index([channel, status])
}

model ContentModerationEvent {
  id          String   @id @default(cuid())
  actorId     String
  action      String
  contentType String
  contentId   String
  contentTitle String
  createdAt   DateTime @default(now())

  actor User @relation("ModerationActor", fields: [actorId], references: [id], onDelete: Restrict)

  @@index([actorId])
  @@index([createdAt])
  @@index([contentType, contentId])
}

enum UserRole {
  MEMBER
  STAFF
  ADMIN
}

model SellerWebsite {
  id          String   @id @default(cuid())
  title       String
  description String
  url         String
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Listing {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Float
  images      String[]
  category    String?
  condition   String?
  status      String   @default("active")
  adult       Boolean  @default(false)
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  reviews      Review[]
  feedback     Feedback[]
  views        ListingView[]
  sections     Json?
  readme       String?

  @@index([userId])
  @@index([status])
  @@index([category])
  @@index([title])
}

// A single view of a listing's detail page. viewerId is null for signed-out
// visitors; the listing owner's own views are never recorded. Powers the
// seller's private analytics ("who's looking at your stuff").
model ListingView {
  id        String   @id @default(cuid())
  listingId String
  viewerId  String?
  createdAt DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  viewer  User?   @relation("ViewerViews", fields: [viewerId], references: [id], onDelete: SetNull)

  @@index([listingId])
  @@index([viewerId])
  @@index([createdAt])
}

model Conversation {
  id        String   @id @default(cuid())
  listingId String?
  directKey String?  @unique
  kind      String   @default("listing")
  buyerId   String
  sellerId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listing  Listing?  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer    User      @relation("ConversationBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  seller   User      @relation("ConversationSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([listingId, buyerId])
  @@index([directKey])
  @@index([kind])
  @@index([buyerId])
  @@index([sellerId])
}

model Message {
  id             String   @id @default(cuid())
  content        String
  conversationId String
  senderId       String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  listingId String
  authorId  String
  createdAt DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  author  User    @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([listingId, authorId])
}

model Feedback {
  id         String   @id @default(cuid())
  rating     Int
  comment    String?
  listingId  String
  fromUserId String
  toUserId   String
  createdAt  DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  from    User    @relation("FeedbackFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  to      User    @relation("FeedbackTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([listingId, fromUserId])
  @@index([toUserId])
  @@index([fromUserId])
}

// First-party, privacy-conscious site analytics. A visitor is a browser, a
// session is a visit, and events describe page views and meaningful clicks.
model AnalyticsVisitor {
  id          String   @id @default(cuid())
  visitorKey  String   @unique
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  sessions    AnalyticsSession[]
  events      AnalyticsEvent[]

  @@index([lastSeenAt])
}

model AnalyticsSession {
  id          String   @id @default(cuid())
  sessionKey  String   @unique
  visitorId   String
  startedAt   DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  entryPath   String
  exitPath    String?
  referrer    String?
  source      String?
  medium      String?
  campaign    String?
  deviceType  String?
  browser     String?
  country     String?
  region      String?
  networkHash String?

  visitor AnalyticsVisitor @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  events  AnalyticsEvent[]

  @@index([visitorId])
  @@index([startedAt])
  @@index([source])
}

model AnalyticsEvent {
  id         String   @id @default(cuid())
  type       String
  path       String
  title      String?
  element    String?
  label      String?
  href       String?
  listingId  String?
  visitorId  String
  sessionId  String
  userId     String?
  occurredAt DateTime @default(now())
  metadata   Json?

  visitor AnalyticsVisitor @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  session AnalyticsSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User?            @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([occurredAt])
  @@index([type, occurredAt])
  @@index([path, occurredAt])
  @@index([listingId, occurredAt])
  @@index([userId, occurredAt])
  @@index([sessionId])
}

model SellerAiState {
  id             String   @id @default(cuid())
  userId         String   @unique
  lastVisitedAt  DateTime?
  lastBriefingAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SellerAiThread {
  id        String   @id @default(cuid())
  userId    String
  title     String   @default("Seller copilot")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages SellerAiMessage[]

  @@index([userId, updatedAt])
}

model SellerAiMessage {
  id        String   @id @default(cuid())
  threadId  String
  role      String
  content   String
  model     String?
  createdAt DateTime @default(now())

  thread SellerAiThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

model SellerMemory {
  id        String   @id @default(cuid())
  userId    String
  kind      String
  content   String
  source    String   @default("conversation")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, kind, content])
  @@index([userId, updatedAt])
}

model AiProviderSettings {
  id              String   @id @default("default")
  provider        String   @default("openrouter")
  model           String   @default("openrouter/auto")
  persona         String?
  encryptedApiKey String?
  keyIv           String?
  keyTag          String?
  updatedById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  updatedBy User? @relation("AiSettingsUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
}

model SiteAudioSettings {
  id          String   @id @default("default")
  enabled     Boolean  @default(false)
  label       String   @default("Builder Radio")
  spotifyUrl  String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  updatedBy User? @relation("AudioSettingsUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
}

model TtsProviderSettings {
  id                      String   @id @default("default")
  provider                String   @default("fish_audio")
  model                   String   @default("s2.1-pro-free")
  referenceId             String?
  encryptedApiKey         String?
  keyIv                   String?
  keyTag                  String?
  ownerBriefingsEnabled   Boolean  @default(true)
  sellerBriefingsEnabled  Boolean  @default(false)
  scheduleEnabled         Boolean  @default(false)
  updatedById             String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  updatedBy User? @relation("TtsSettingsUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
}
