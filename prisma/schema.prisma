generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(cuid())
  name      String?
  email     String    @unique
  password  String?
  image     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  listings            Listing[]
  messages            Message[]
  conversationsAsBuyer  Conversation[] @relation("ConversationBuyer")
  conversationsAsSeller Conversation[] @relation("ConversationSeller")
  reviewsGiven Review[]        @relation("ReviewAuthor")
  feedbackGiven   Feedback[]    @relation("FeedbackFrom")
  feedbackReceived Feedback[]   @relation("FeedbackTo")
  listingViews  ListingView[]  @relation("ViewerViews")
  websites      SellerWebsite[]
  role          UserRole       @default(MEMBER)
  analyticsEvents AnalyticsEvent[]
  sellerAiState    SellerAiState?
  sellerAiThreads  SellerAiThread[]
  sellerMemories   SellerMemory[]
  aiSettingsUpdated AiProviderSettings[] @relation("AiSettingsUpdatedBy")
}

enum UserRole {
  MEMBER
  STAFF
  ADMIN
}

model SellerWebsite {
  id          String   @id @default(cuid())
  title       String
  description String
  url         String
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Listing {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Float
  images      String[]
  category    String?
  condition   String?
  status      String   @default("active")
  adult       Boolean  @default(false)
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  reviews      Review[]
  feedback     Feedback[]
  views        ListingView[]
  sections     Json?
  readme       String?

  @@index([userId])
  @@index([status])
  @@index([category])
  @@index([title])
}

// A single view of a listing's detail page. viewerId is null for signed-out
// visitors; the listing owner's own views are never recorded. Powers the
// seller's private analytics ("who's looking at your stuff").
model ListingView {
  id        String   @id @default(cuid())
  listingId String
  viewerId  String?
  createdAt DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  viewer  User?   @relation("ViewerViews", fields: [viewerId], references: [id], onDelete: SetNull)

  @@index([listingId])
  @@index([viewerId])
  @@index([createdAt])
}

model Conversation {
  id        String   @id @default(cuid())
  listingId String
  buyerId   String
  sellerId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listing  Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer    User      @relation("ConversationBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  seller   User      @relation("ConversationSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([listingId, buyerId])
  @@index([buyerId])
  @@index([sellerId])
}

model Message {
  id             String   @id @default(cuid())
  content        String
  conversationId String
  senderId       String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  listingId String
  authorId  String
  createdAt DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  author  User    @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([listingId, authorId])
}

model Feedback {
  id         String   @id @default(cuid())
  rating     Int
  comment    String?
  listingId  String
  fromUserId String
  toUserId   String
  createdAt  DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  from    User    @relation("FeedbackFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  to      User    @relation("FeedbackTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([listingId, fromUserId])
  @@index([toUserId])
  @@index([fromUserId])
}

// First-party, privacy-conscious site analytics. A visitor is a browser, a
// session is a visit, and events describe page views and meaningful clicks.
model AnalyticsVisitor {
  id          String   @id @default(cuid())
  visitorKey  String   @unique
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  sessions    AnalyticsSession[]
  events      AnalyticsEvent[]

  @@index([lastSeenAt])
}

model AnalyticsSession {
  id          String   @id @default(cuid())
  sessionKey  String   @unique
  visitorId   String
  startedAt   DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  entryPath   String
  exitPath    String?
  referrer    String?
  source      String?
  medium      String?
  campaign    String?
  deviceType  String?
  browser     String?
  country     String?
  region      String?
  networkHash String?

  visitor AnalyticsVisitor @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  events  AnalyticsEvent[]

  @@index([visitorId])
  @@index([startedAt])
  @@index([source])
}

model AnalyticsEvent {
  id         String   @id @default(cuid())
  type       String
  path       String
  title      String?
  element    String?
  label      String?
  href       String?
  listingId  String?
  visitorId  String
  sessionId  String
  userId     String?
  occurredAt DateTime @default(now())
  metadata   Json?

  visitor AnalyticsVisitor @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  session AnalyticsSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User?            @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([occurredAt])
  @@index([type, occurredAt])
  @@index([path, occurredAt])
  @@index([listingId, occurredAt])
  @@index([userId, occurredAt])
  @@index([sessionId])
}

model SellerAiState {
  id             String   @id @default(cuid())
  userId         String   @unique
  lastVisitedAt  DateTime?
  lastBriefingAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SellerAiThread {
  id        String   @id @default(cuid())
  userId    String
  title     String   @default("Seller copilot")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages SellerAiMessage[]

  @@index([userId, updatedAt])
}

model SellerAiMessage {
  id        String   @id @default(cuid())
  threadId  String
  role      String
  content   String
  model     String?
  createdAt DateTime @default(now())

  thread SellerAiThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

model SellerMemory {
  id        String   @id @default(cuid())
  userId    String
  kind      String
  content   String
  source    String   @default("conversation")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, kind, content])
  @@index([userId, updatedAt])
}

model AiProviderSettings {
  id              String   @id @default("default")
  provider        String   @default("openrouter")
  model           String   @default("openrouter/auto")
  encryptedApiKey String?
  keyIv           String?
  keyTag          String?
  updatedById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  updatedBy User? @relation("AiSettingsUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
}
